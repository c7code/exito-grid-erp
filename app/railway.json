{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "app/Dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c \"serve /app/dist -s -l ${PORT:-3000}\"",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
